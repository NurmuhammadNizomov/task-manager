# ===========================================
# Task Manager - Environment Configuration
# ===========================================
# Copy this file to .env and update the values
# ===========================================

# Database Configuration
# ===================
# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/task-manager

# Database name
MONGODB_DB_NAME=task-manager

# Redis Configuration
# ==================
# Redis connection string (use rediss:// for SSL)
REDIS_URL=redis://localhost:6379

# Redis key prefix for multi-tenant support
REDIS_PREFIX=task-manager

# JWT Configuration
# =================
# Secret for signing access tokens (generate a strong random string)
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production-min-32-chars

# Secret for signing refresh tokens (generate a different strong random string)
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-32-chars

# Access token expiration time
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token expiration time
JWT_REFRESH_EXPIRES_IN=7d

# Email Configuration (SMTP)
# ==========================
# Gmail: use App Password (not your regular password)
# Enable 2FA and generate App Password at: myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Task Manager <your-email@gmail.com>

# Application Configuration
# ======================
# Base URL of your application
# Development: http://localhost:3000
# Production: https://yourdomain.com
APP_BASE_URL=http://localhost:3000

# Google OAuth Configuration
# =========================
# Google Client ID from Google Cloud Console
# Get this from: https://console.developers.google.com -> Credentials -> OAuth Client ID
NUXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ===========================================
# Security Notes
# ===========================================
# 1. Generate strong secrets using: openssl rand -base64 32
# 2. Never commit .env file to version control
# 3. Use different secrets for development and production
# 4. Rotate secrets regularly in production
# 5. Use environment-specific .env files when needed
# ===========================================

# ===========================================
# Development vs Production
# ===========================================
# Development: Use this file as .env
# Production: Create separate .env.production file
# Testing: Create separate .env.test file
# ===========================================
